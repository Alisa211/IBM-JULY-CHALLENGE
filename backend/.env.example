# Database Configuration
DATABASE_URL=postgresql+asyncpg://muse_user:muse_password@localhost:5432/muse_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Storage Configuration
STORAGE_URL=file:///storage/

# Watsonx.ai Configuration
# Get your API key from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_ibm_cloud_api_key_here
# Get your project ID from: https://dataplatform.cloud.ibm.com/wx/home
WATSONX_PROJECT_ID=your_watsonx_project_id_here
# API endpoint (default: US South)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
# Model to use for generation
WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2

# Application Configuration
SECRET_KEY=supersecretkey_change_in_prod
PROJECT_NAME=MuseEngine API
VERSION=1.0.0
API_V1_STR=/api/v1